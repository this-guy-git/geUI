{
  "name": "geui",
  "version": "0.1.0",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "webpack --mode production",
    "dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron-builder": "^24.13.3",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "build": {
    "appId": "com.geui.launcher",
    "productName": "geUI",
    "asar": true,
    "files": [
      "main.js",
      "index.html",
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "geUI.exe"
    }
  }
}
